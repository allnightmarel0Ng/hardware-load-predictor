# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://predictor:predictor@db:5432/predictor

# ── Prometheus ────────────────────────────────────────────────────────────────
METRICS_SOURCE_URL=http://prometheus:9090

# Set to true for local dev without a real Prometheus instance
USE_PROMETHEUS_STUB=false

# PromQL expressions for system metrics (node_exporter defaults)
# Override if your labels, job names, or instance filters differ
PROMETHEUS_CPU_QUERY=100 - avg(irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100
PROMETHEUS_RAM_GB_QUERY=(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1073741824
PROMETHEUS_RAM_PCT_QUERY=(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100
PROMETHEUS_NET_QUERY=sum(irate(node_network_receive_bytes_total[5m])) * 8 / 1048576
PROMETHEUS_DISK_QUERY=avg(irate(node_disk_io_time_seconds_total[5m])) * 100

# ── ML ────────────────────────────────────────────────────────────────────────
MODEL_STORAGE_PATH=/app/models
ACCURACY_THRESHOLD=0.85
RETRAIN_INTERVAL_HOURS=24

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TRAINING_MAX_WORKERS=4
